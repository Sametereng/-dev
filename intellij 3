// KARGOLAR
class KargoPaketi {
    double desi;      
    int mesafeKodu;   

    // veri alma
    public KargoPaketi(double desi, int mesafeKodu) {
        this.desi = desi;
        this.mesafeKodu = mesafeKodu;
    }

    // hesap döngüsü
    public double fiyatHesapla() {
        double birimFiyat = 25.0;
        double toplam;

        // mesafeye göre fiyat
        if (mesafeKodu == 3) {
            toplam = desi * birimFiyat * 5; // Uluslararası 5
        } else if (mesafeKodu == 2) {
            toplam = desi * birimFiyat * 2; // Şehirler arası 2
        } else {
            toplam = desi * birimFiyat;     // Şehir içi normal
        }
        return toplam;
    }
}.

public class LojistikSistemi {
    public static void main(String[] args) {
        System.out.println("--- Günlük Sevkiyat Listesi ---");

        // günlük 3 farklı kargonun fiyatını otomatik hesaplar
        for (int i = 1; i <= 3; i++) {
            KargoPaketi p = new KargoPaketi(i * 1.5, i); 
            
            // ekrana bastırma kodu
            System.out.println(i + ". Kargonun Ücreti: " + p.fiyatHesapla() + " TL");
        }
    }
}
