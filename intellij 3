// SINIF YAPISI: Her kargo paketi bir nesnedir
class KargoPaketi {
    double desi;      // Ağırlık ve hacim birimi
    int mesafeKodu;   // 1: Şehir içi, 2: Şehirler arası, 3: Uluslararası

    // Constructor (Yapıcı Metot): Nesne oluşturulurken verileri alır
    public KargoPaketi(double desi, int mesafeKodu) {
        this.desi = desi;
        this.mesafeKodu = mesafeKodu;
    }

    // METOT: Ücret hesaplayan fonksiyon
    public double fiyatHesapla() {
        double birimFiyat = 25.0;
        double toplam;

        // KARAR YAPISI: Mesafeye göre fiyatı katla
        if (mesafeKodu == 3) {
            toplam = desi * birimFiyat * 5; // Uluslararası 5 katı
        } else if (mesafeKodu == 2) {
            toplam = desi * birimFiyat * 2; // Şehirler arası 2 katı
        } else {
            toplam = desi * birimFiyat;     // Şehir içi standart
        }
        return toplam;
    }
}

public class LojistikSistemi {
    public static void main(String[] args) {
        System.out.println("--- Günlük Sevkiyat Listesi ---");

        // DÖNGÜ (For): Günlük 3 farklı kargonun fiyatını otomatik hesapla
        for (int i = 1; i <= 3; i++) {
            // Nesne oluşturma (Her döngüde yeni bir paket nesnesi)
            KargoPaketi p = new KargoPaketi(i * 1.5, i); 
            
            // Metot kullanarak sonucu ekrana bas
            System.out.println(i + ". Kargonun Ücreti: " + p.fiyatHesapla() + " TL");
        }
    }
}
